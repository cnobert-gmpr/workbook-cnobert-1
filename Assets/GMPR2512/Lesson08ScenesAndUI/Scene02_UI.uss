.root
{
    flex-grow: 1;
    justify-content: flex-start;
    align-items: flex-start;
    padding-top: 16px;
    padding-left: 16px;
}

.score-label
{
    font-size: 44px;
    color: white;
    background-color: rgba(0, 0, 0, 0.65);
    padding-top: 8px;
    padding-right: 12px;
    padding-bottom: 8px;
    padding-left: 12px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
}